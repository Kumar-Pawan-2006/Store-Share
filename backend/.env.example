PORT=5000

# ---- Database (Neon PostgreSQL) ----
# Paste your Neon pooled connection string here.
DATABASE_URL="postgresql://user:password@host-pooled.neon.tech/dbname?sslmode=require"

# Neon direct/unpooled URL — required only for migrations
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
