datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum Role {
  ADMIN
  SOCIETY_MANAGER
}

enum Status {
  ONBOARDING
  ACTIVE
  PAUSED
}

enum HealthStatus {
  GOOD
  WARNING
  CRITICAL
}

enum PayoutStatus {
  PENDING
  PAID
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String
  role           Role     @default(SOCIETY_MANAGER)
  name           String
  societyId      String?  @unique
  society        Society? @relation(fields: [societyId], references: [id], onDelete: Cascade)
}

model Society {
  id                      String               @id @default(uuid())
  name                    String
  address                 String
  city                    String
  flatCount               Int
  rooftopSolarKw          Float
  dailySurplusUnits       Float
  netMeteringRate         Float                @default(2.0)
  discomImportRate        Float                @default(8.5)
  revenueSplitCustomerPct Float                @default(60.0)
  revenueSplitCompanyPct  Float                @default(40.0)
  contactPersonName       String
  contactEmail            String
  contactPhone            String
  status                  Status               @default(ONBOARDING)
  onboardedAt             DateTime             @default(now())
  internalNotes           String?              @default("")
  
  user                    User?
  batteryUnit             BatteryUnit?
  energyReadings          EnergyReading[]
  revenueTransactions     RevenueTransaction[]
  amcContracts            AMCContract[]
}

model BatteryUnit {
  id                   String       @id @default(uuid())
  societyId            String       @unique
  society              Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  manufacturerPartner  String
  capacityKwh          Float
  leaseOrRevShareTerms String
  installDate          DateTime
  healthStatus         HealthStatus @default(GOOD)
  lastServiceDate      DateTime
  nextMaintenanceDue   DateTime
}

model EnergyReading {
  id                    String   @id @default(uuid())
  societyId             String
  society               Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  date                  DateTime
  surplusUnitsGenerated Float
  unitsStoredInBattery  Float
  unitsUsedFromBattery  Float
  unitsExportedToGrid   Float

  @@unique([societyId, date])
}

model RevenueTransaction {
  id                String       @id @default(uuid())
  societyId         String
  society           Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  date              DateTime     
  baselineValue     Float
  platformValue     Float
  extraValueCreated Float
  customerEarning   Float
  companyRevenue    Float
  payoutStatus      PayoutStatus @default(PENDING)
}

model AMCContract {
  id                   String      @id @default(uuid())
  societyId            String
  society              Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  monthlyFee           Float
  startDate            DateTime
  renewalDate          DateTime
  status               Status      @default(ACTIVE)
  lastMaintenanceCheck DateTime
  nextMaintenanceDue   DateTime
}

model B2BLead {
  id           String     @id @default(uuid())
  companyName  String
  contactEmail String
  interestType String     
  status       LeadStatus @default(NEW)
  notes        String?
  createdAt    DateTime   @default(now())
}
