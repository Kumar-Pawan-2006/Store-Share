# ==========================================
# Store & Share - Environment Configuration
# ==========================================

# 1. Database Connections (Neon PostgreSQL serverless)
# Configure these variables in your Vercel project settings or .env file.
# The pooled URL is used for the main Prisma connections.
DATABASE_URL="postgresql://[user]:[password]@[neon-host]/[db]?sslmode=require&pgbouncer=true"

# The direct (unpooled) URL is used to perform migrations and DB schemas.
DIRECT_URL="postgresql://[user]:[password]@[neon-host]/[db]?sslmode=require"

# 2. NextAuth Authentication Configurations
# Generate a secure secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_jwt_signing_secret_here"

# The absolute base URL of your application. Set to http://localhost:3000 for local runs.
NEXTAUTH_URL="http://localhost:3000"
